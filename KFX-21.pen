            24,
            32
          ],
          "children": [
            {
              "type": "frame",
              "id": "FkgNm",
              "name": "section_header",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 4,
              "children": [
                {
                  "type": "text",
                  "id": "457pr",
                  "name": "cssHdrTxt",
                  "fill": "#1A1A2E",
                  "content": "CSS STYLESHEET CODE",
                  "fontFamily": "Noto Sans",
                  "fontSize": 11,
                  "fontWeight": "700",
                  "letterSpacing": 3
                },
                {
                  "type": "rectangle",
                  "id": "8LiU4",
                  "name": "cssHdrDiv",
                  "fill": "#D1CCC4",
                  "width": "fill_container",
                  "height": 1
                }
              ]
            },
            {
              "type": "frame",
              "id": "RB7g1",
              "name": "css_code_block",
              "width": "fill_container",
              "fill": "#1A1A2E",
              "cornerRadius": 8,
              "layout": "vertical",
              "padding": [
                16,
                20
              ],
              "children": [
                {
                  "type": "text",
                  "id": "TUaZt",
                  "name": "cssLine1",
                  "fill": "#6BB6B0",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "/* ===== KF-21 LIS · BOARD-LIGHT_re Stylesheet ===== */",
                  "fontFamily": "Noto Sans",
                  "fontSize": 12,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "5SBeJ",
                  "name": "cssLine2",
                  "fill": "#FFFFFF",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": ":root {",
                  "fontFamily": "Noto Sans",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "OtowB",
                  "name": "cssLine3",
                  "fill": "#E0E3EB",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "  /* Colors */\n  --color-navy:       #1A1A2E;\n  --color-green:      #4A7C59;   /* $success */\n  --color-teal:       #6BB6B0;   /* $accent-teal */\n  --color-orange:     #E89B5C;   /* $accent-orange */\n  --color-red:        #B54A4A;   /* $error */\n  --color-gray:       #6B6B80;   /* text-secondary */\n  --color-border:     #E0E3EB;\n  --color-bg-page:    #F4F4F5;\n  --color-bg-card:    #FFFFFF;\n  --color-cyan:       #23D3EE;",
                  "fontFamily": "Noto Sans",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "fd2Ak",
                  "name": "cssLine4",
                  "fill": "#E0E3EB",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "  /* Typography */\n  --font-primary:     'Noto Sans', sans-serif;\n  --font-logo:        'Inter', sans-serif;\n\n  /* Spacing */\n  --sp-xs: 4px;   --sp-sm: 8px;  --sp-md: 12px;\n  --sp-lg: 16px;  --sp-xl: 20px; --sp-2xl: 24px;\n}",
                  "fontFamily": "Noto Sans",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "rMoVc",
                  "name": "cssLine5",
                  "fill": "#E0E3EB",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "\n/* ----- Typography ----- */\n.text-logo    { font-family:var(--font-primary); font-size:22px; font-weight:700; line-height:1; color:var(--color-navy); letter-spacing:1px; }\n.text-heading { font-family:var(--font-primary); font-size:18px; font-weight:700; line-height:1; color:var(--color-navy); letter-spacing:2px; }\n.tab-label--active { font-family:var(--font-primary); font-size:14px; font-weight:700; line-height:1; color:var(--color-navy); letter-spacing:2px; }\n.tab-label         { font-family:var(--font-primary); font-size:14px; font-weight:600; line-height:1; color:#767676; letter-spacing:2px; }\n.menu-col-header   { font-family:var(--font-primary); font-size:11px; font-weight:600; line-height:1; color:#767676; letter-spacing:1.5px;\n                     padding:4px 12px 8px; }\n.menu-item__label--active { font-family:var(--font-primary); font-size:13px; font-weight:600; line-height:1; color:var(--color-navy); }\n.menu-item__label         { font-family:var(--font-primary); font-size:13px; font-weight:500; line-height:1; color:#444444; }",
                  "fontFamily": "Noto Sans",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Jjmwb",
                  "name": "cssLine6",
                  "fill": "#E0E3EB",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "\n/* ----- Buttons ----- */\n.btn-primary {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  padding: 6px 12px;\n  border-radius: 25px;\n  background-color: var(--color-navy);\n  color: #ffffff;\n  font-family: var(--font-primary);\n  font-size: 14px;\n  font-weight: 600;\n  line-height: 1;\n  letter-spacing: 1px;\n  border: 1px solid transparent;\n}\n.btn-dark {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  height: 32px;\n  padding: 0 16px;\n  border-radius: 8px;\n  background-color: #0f172a;\n  color: var(--color-cyan);\n  font-family: var(--font-primary);\n  font-size: 14px;\n  font-weight: 600;\n  line-height: 1;\n  border: 1px solid var(--color-border);\n}",
                  "fontFamily": "Noto Sans",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "tFnU4",
                  "name": "cssLine7",
                  "fill": "#E0E3EB",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "\n/* ----- Top Bar ----- */\n.top-bar {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  height: 48px;\n  padding: 0 16px;\n  background-color: var(--color-bg-card);\n  border-bottom: 1px solid var(--color-border);\n}\n.top-bar__logo-area {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  width: 220px;\n}\n.top-bar__logo-badge {\n  font-family: 'Inter', sans-serif;\n  font-size: 12px;\n  font-weight: 700;\n  color: var(--color-green);\n}\n.top-bar__logo-title {\n  font-family: var(--font-primary);\n  font-size: 18px;\n  font-weight: 600;\n  color: var(--color-navy);\n}\n.top-bar__tabs {\n  display: flex;\n  align-items: center;\n  height: 100%;\n}\n.top-bar__hamburger {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 48px;\n  height: 48px;\n}\n/* ---- Tab States ---- */\n.tab {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 48px;\n  padding: 0 16px;\n  font-family: var(--font-primary);\n  font-size: 14px;\n  letter-spacing: 2px;\n  cursor: pointer;\n  border-radius: 4px 4px 0 0;\n  transition: background-color 0.15s, border-bottom-color 0.15s;\n}\n.tab--off {\n  background-color: transparent;\n  border-bottom: none;\n  font-weight: 600;\n  color: #767676;\n}\n.tab--on {\n  background-color: #FFFFFF;\n  border-bottom: 2px solid var(--color-green);\n  font-weight: 700;\n  color: var(--color-navy);\n}\n.tab:hover,\n.tab--hover {\n  background-color: #F8F9FA;\n  border-bottom: 2px solid #C8D0DE;\n  font-weight: 600;\n  color: #555566;\n}\n/* ---- TopBar Right ---- */\n.top-bar__right {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  width: 280px;\n  justify-content: flex-end;\n}\n.top-bar__user-label {\n  font-family: var(--font-primary);\n  font-size: 14px;\n  font-weight: 500;\n  color: #6B6B80;\n  letter-spacing: 1px;\n}\n/* ---- Bottom Tab Bar ---- */\n.bottom-tab-bar {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 48px;\n  background-color: var(--color-bg-card);\n  border-top: 1px solid var(--color-border);\n}\n.btab {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100%;\n  width: 120px;\n}\n.btab--active {\n  border-bottom: 2px solid var(--color-green);\n}",
                  "fontFamily": "Noto Sans",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "HPznb",
                  "name": "cssLine8",
                  "fill": "#E0E3EB",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "\n/* ----- Cards ----- */\n.card {\n  background-color: var(--color-bg-card);\n  border-radius: 16px;\n  padding: 20px 18px;\n  border: 1px solid var(--color-border);\n  box-shadow: 0 2px 3.5px rgba(0,0,0,0.06),\n              0 4px 5.25px rgba(0,0,0,0.10);\n}\n.card-glass {\n  background-color: rgba(255,255,255,0.5);\n  border-radius: 12px;\n  padding: 16px;\n  border: 1px solid rgba(224,227,235,0.01);\n}\n/* ----- Submenu Popover ----- */\n.submenu-popover {\n  background-color: var(--color-bg-card);\n  border-radius: 0 8px 8px 8px;\n  border: 1px solid var(--color-border);\n  border-top: none;\n  box-shadow: 0 4px 16px rgba(0,0,0,0.09),\n              0 1px 3px  rgba(0,0,0,0.07);\n}",
                  "fontFamily": "Noto Sans",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "1yPQI",
                  "name": "cssLine9",
                  "fill": "#E0E3EB",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "\n/* ----- Menu Items ----- */\n.menu-item {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  height: 36px;\n  padding: 0 12px;\n  border-radius: 4px;\n  cursor: pointer;\n}\n.menu-item--active { background-color: #EEF2FF; }\n.menu-item:hover   { background-color: #F4F5FF; }\n\n/* ----- Badges ----- */\n.badge-success {\n  background-color: rgba(74,124,89,0.13);\n  border-radius: 4px;\n  padding: 4px 8px;\n  font-family: var(--font-primary);\n  font-size: 14px;\n  font-weight: 700;\n  color: var(--color-green);\n}\n.badge-info {\n  background-color: #DBEAFE;\n  border-radius: 9px;\n  height: 18px;\n  padding: 0 6px;\n  font-family: var(--font-primary);\n  font-size: 10px;\n  font-weight: 700;\n  color: #1D4ED8;\n}\n.badge-error {\n  background-color: rgba(181,74,74,0.13);\n  border-radius: 4px;\n  padding: 4px 8px;\n  font-family: var(--font-primary);\n  font-size: 12px;\n  font-weight: 700;\n  color: var(--color-red);\n}\n.badge-warning {\n  background-color: rgba(232,155,92,0.13);\n  border-radius: 4px;\n  padding: 4px 8px;\n  font-family: var(--font-primary);\n  font-size: 12px;\n  font-weight: 700;\n  color: var(--color-orange);\n}",
                  "fontFamily": "Noto Sans",
                  "fontSize": 12,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
